# Local .terraform directories (downloaded provider plugins - large, regenerated by terraform init)
**/.terraform/*

# Terraform lock file - commit this if you want consistent provider versions across team
# .terraform.lock.hcl

# State files - NEVER commit these (contain sensitive data, managed by remote backend)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Sensitive variable files - NEVER commit these
*.tfvars.json
# Note: terraform.tfvars is committed here because it has no secrets in this project.
# If it ever contains passwords/keys, add it here.

# Override files (local developer overrides - not for team use)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config file
.terraformrc
terraform.rc
